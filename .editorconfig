root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.java]
indent_style = space
indent_size = 2
continuation_indent_size = 2
max_line_length = 85

# IntelliJ: never collapse imports to wildcard
ij_java_class_count_to_use_import_on_demand = 999
ij_java_names_count_to_use_import_on_demand = 999

# IntelliJ: one blank line between import groups,
# none within a group
ij_java_imports_layout = *,|,javax.**,|,java.**,|,$*

# IntelliJ: blank lines
ij_java_blank_lines_after_imports = 1
ij_java_blank_lines_before_imports = 0
ij_java_blank_lines_before_method_body = 1
ij_java_blank_lines_around_method = 2

# IntelliJ: chained method calls and wrapped
# parameters use a fixed continuation indent (4)
# rather than aligning to the opening parenthesis.
# This keeps chained builders like RestClient and
# UriComponentsBuilder readable within 85 chars.
ij_java_align_multiline_chained_methods = false
ij_java_align_multiline_parameters = false
ij_java_align_multiline_parameters_in_calls = false
ij_java_align_multiline_binary_operation = false

# IntelliJ: only wrap when the line would exceed
# max_line_length — never force wrapping short
# expressions onto multiple lines.
ij_java_method_call_chain_wrap = normal
ij_java_call_parameters_wrap = normal
ij_java_binary_operation_wrap = normal

# IntelliJ: method-declaration parameters wrap one
# per line when the signature exceeds max_line_length.
# Call-site arguments use compact wrap (normal above).
ij_java_method_declaration_parameters_wrap = on_every_item

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{html,xml}]
indent_style = space
indent_size = 2
max_line_length = off

[*.{css,scss}]
indent_style = space
indent_size = 2

[*.{js,json}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off
